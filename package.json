    "build": "bun run scripts/build.ts",
    "build:dev": "bun run scripts/build.ts --dev",
    "build:sourcemap": "bun run scripts/build.ts --sourcemap",
    "typecheck": "bun run tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "dev": "bun src/entrypoints/cli.tsx"
